generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int              @id @default(autoincrement())
  createdAt DateTime         @default(now())
  email     String           @unique
  name      String
  hash      String
  gardens   Garden[]
  plants    Plant[]
  headUnit  HeadUnit[]
  sensors   MoistureSensor[]
}

model Garden {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  gardenName String
  user       User      @relation(fields: [userId], references: [id])
  userId     Int       
  plants     Plant[]
  headUnit   HeadUnit?
}

model Plant {
  id                     Int             @id @default(autoincrement())
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  plantName              String
  imageUrl               String?
  plantSpecies           String?
  plantDescription       String?
  sunlightPreference     String?
  wateringIntervalSummer Int?
  wateringIntervalWinter Int?
  lastWateredAt          DateTime?
  nextWateredAt          DateTime?
  optimalMoistureLevel   Int?
  isToxicToPets          Boolean?
  garden                 Garden?         @relation(fields: [gardenId], references: [id])
  gardenId               Int?            
  user                   User            @relation(fields: [userId], references: [id])
  userId                 Int             
  sensor                 MoistureSensor?
}

model MoistureSensor {
  id         Int               @id @default(autoincrement())
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  macAddress String            @unique
  user       User              @relation(fields: [userId], references: [id])
  userId     Int               
  plant      Plant?            @relation(fields: [plantId], references: [id])
  plantId    Int?              @unique
  history    MoistureHistory[]
}

model MoistureHistory {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  moistureLevel Int
  sensor        MoistureSensor @relation(fields: [sensorId], references: [id])
  sensorId      Int
  batteryLevel  Int?
}

// HeadUnit can be assigned to a Garden, but must be assigned to a User
model HeadUnit {
  id         Int                  @id @default(autoincrement())
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  macAddress String               @unique
  user       User                 @relation(fields: [userId], references: [id])
  userId     Int
  garden     Garden?              @relation(fields: [gardenId], references: [id])
  gardenId   Int?                 @unique
  history    EnvironmentHistory[]
}

model EnvironmentHistory {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  tempLevel    Float
  moistLevel   Int
  headUnit     HeadUnit @relation(fields: [headUnitId], references: [id])
  headUnitId   Int
  batteryLevel Int?
}
